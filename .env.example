# Copy this file to .env.local and fill values for each machine.

# App
NEXT_PUBLIC_APP_NAME=GreenMiles
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase client values
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only Supabase values. Never expose these in client code.
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PROJECT_REF=
SUPABASE_ACCESS_TOKEN=

# Database connection string for migrations, scripts, or server jobs.
DATABASE_URL=

# Optional receipt OCR. Keep disabled for the MVP unless explicitly testing OCR.
ENABLE_RECEIPT_OCR=false
OPENAI_API_KEY=

# Testnet-only blockchain anchoring. Never add mainnet private keys.
POLYGON_AMOY_RPC_URL=
POLYGON_AMOY_PRIVATE_KEY=
GREENMILES_ANCHOR_CONTRACT_ADDRESS=
